node_modules/
dist/
coverage/
.env
*.log
.DS_Store
.gstack/
.codegraph/

# Peaks transient/per-session state (regenerable, not shared knowledge)
.peaks/**/.bypass-count.json
.peaks/ontology.json
# Peaks runtime state — canonical home at .peaks/_runtime/ (active-skill, session binding, sop-state, future hooks/output-style state)
.peaks/_runtime/
# Top-level .peaks/session.json (CLI's external session metadata file; appears alongside .peaks/_runtime/session.json — distinct file, not under _runtime/)
.peaks/session.json
# Test / debug backups left by sub-agent baselines (e.g. .peaks/.active-skill.json.test-bak from QA's git-stash verification)
.peaks/*.bak
.peaks/*.test-bak
.peaks/**/*.bak
.peaks/**/*.test-bak
# Note: the per-slice session artifacts under .peaks/<session-id>/{prd,rd,qa,sc,txt,system}/ ARE tracked by convention (提交中间产物); only the runtime state above is ignored.
