node_modules/
dist/
coverage/
.env
*.log
.DS_Store
.gstack/
.codegraph/
.peaks/_runtime/
# slice 2.5.0 sub-fix C: peaks playwright start session records.
# The directory lives under _runtime/ so it is already covered by
# the rule above; this explicit line documents the intent for
# future readers (and survives a future rule refactor).
.peaks/_runtime/playwright-sessions/
.peaks/_dogfood/
.peaks/_sub_agents/
.peaks/audit/
.peaks/DS_Store/
.peaks/system/       # sub-agent dispatch prompts (rd-prompt-*.txt, qa-prompt-*.txt); ephemeral session state, mirror of _sub_agents/
# Archive of bare/invalid sids moved by `peaks workspace clean --sub-agents --invalid`.
# Holds historical dispatch records from bare sids (sid-3, sid-h, sid-r, sid-perf,
# unknown-sid, etc.) — kept for forensic value but not part of the active workspace.
.peaks/_archive/
# Defensive: .peaks/runtime/ (no underscore) is a wrong-path pattern; canonical is .peaks/_runtime/
.peaks/runtime/
# Per-project user state (spec §8.4); regenerated by preferences-service on first read.
.peaks/preferences.json
# Auto-generated upgrade record from `peaks upgrade --to 2.0`; per-installation artifact, not source-of-truth.
.peaks/memory/upgrade-2.0-*.md
# Defense (slice 2026-06-22-top-level-change-id-cleanup): no YYYY-MM-DD-prefixed
# directories are allowed at `.peaks/` top level. change-id / session-id style
# dirs must live under `.peaks/_runtime/<sid>/` (gitignored) — never as siblings.
# Matches: .peaks/2026-06-22-cc-connect-orphan-cleanup/, .peaks/2026-06-21-... etc.
# Does NOT match: .peaks/_runtime/2026-06-22-session-14216e/ (underscore prefix).
.peaks/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]-*/
# Dogfood / scratch test runners; ephemeral, never source-of-truth.
.tmp/
