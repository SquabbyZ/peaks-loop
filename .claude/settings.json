{
  "statusLine": {
    "type": "command",
    "command": "peaks statusline",
    "padding": 0
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "peaks gate enforce --project \"${CLAUDE_PROJECT_DIR}\""
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "peaks progress start --project \"${CLAUDE_PROJECT_DIR}\" --reason \"auto-spawn for sub-agent Task\" --quiet"
          }
        ]
      }
    ]
  }
}
