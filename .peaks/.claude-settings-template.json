{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const p=process.argv[1]||\\\"\\\";if(p.includes(\\\".peaks/_runtime/\\\"))process.exit(0);const m=p.match(/\\.peaks\\/([a-z0-9][a-z0-9.-]*)\\//);if(m&&m[1]&&m[1]!==\\\"_runtime\\\"&&m[1]!==\\\"_dogfood\\\"&&m[1]!==\\\"_sub_agents\\\"&&m[1]!==\\\"memory\\\"&&m[1]!==\\\"sops\\\"&&m[1]!==\\\"retrospective\\\"&&m[1]!==\\\"project-scan\\\"&&m[1]!==\\\"perf-baseline\\\")process.exit(0);process.exit(1)\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "peaks solo gate-step-08 --project \"${CLAUDE_PROJECT_DIR}\""
          }
        ]
      }
    ]
  }
}
