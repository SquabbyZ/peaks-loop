# peaks-loop repo-local .npmrc template (v2.14.1)
#
# npm 11.x config-key migration note:
#   `https_proxy` (underscore) is NO LONGER VALID in npm 11+.
#   npm 11.x warns: "Unknown user config 'https_proxy'. This will stop
#   working in the next major version of npm." npm 12 will hard-error.
#
# Use the dashed variants:
#   proxy=<URL>        -> for HTTP requests
#   https-proxy=<URL>  -> for HTTPS requests (preferred replacement for https_proxy)
#
# Empty by default — contributors fill in only what they need.
# This file is checked in to document the migration; it does NOT
# override the user-global ~/.npmrc (which may still contain the
# deprecated underscored key — user must run
#   npm config delete https_proxy
# themselves to silence the npm 11.x warning).

# pnpm 10.11+ migration (ice-cola surface check 2026-07-22, follow-on
# to report item 5.4): the legacy `package.json#pnpm.onlyBuiltDependencies`
# field is no longer read by pnpm 10.11 (pnpm@latest deprecation;
# pnpm logs `WARN  The "pnpm" field in package.json is no longer read
# by pnpm`). The setting now lives in .npmrc as `onlyBuiltDependencies`
# (the canonical pnpm config key), keeping better-sqlite3's native
# build step on `pnpm install`.
onlyBuiltDependencies=better-sqlite3
